<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-900">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RakshaPath - Live Map Routing</title>

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.css"
        integrity="sha512-Zcn6bjR/8RZbLEpLIeOwNtzREBAJnUKESxces60Mpoj+2okopSAcSUIUOseddDm0cxnGQzxIR7vJgsLZbdLE3w=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Leaflet Routing Machine CSS -->
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/leaflet-routing-machine/3.2.12/leaflet-routing-machine.css" />

    <style>
        /* Hide the default messy route directions text panel safely */
        .leaflet-routing-container {
            display: none !important;
        }
    </style>
</head>

<body class="h-full flex flex-col font-sans text-slate-200 overflow-hidden">

    <!-- Modern Navigation Bar -->
    <nav
        class="bg-slate-950 border-b border-slate-800 px-4 py-3 flex flex-wrap justify-between items-center gap-4 z-50 shadow-md">
        <div class="flex items-center space-x-3">
            <!-- Shield Icon Logo -->
            <div class="bg-red-500/10 p-2 rounded-lg text-red-500 border border-red-500/20">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                    stroke="currentColor" class="w-6 h-6">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
            </div>
            <div>
                <span class="font-bold text-white text-lg tracking-wide">RakshaPath</span>
                <span class="hidden sm:inline text-slate-500 text-sm mx-2">|</span>
                <span class="text-sm text-slate-400 block sm:inline">
                    Logged in: <span class="text-sky-400 font-medium">
                        <%= user.name %>
                    </span>
                </span>
            </div>
        </div>

        <div class="flex items-center space-x-3 text-sm">
            <a href="/create-room"
                class="bg-emerald-600 hover:bg-emerald-500 text-white font-medium px-4 py-2 rounded-lg transition-colors duration-200 shadow-sm shadow-emerald-900/20">
                Create Room
            </a>
            <a href="/logout"
                class="bg-slate-800 hover:bg-slate-700 text-slate-300 font-medium px-4 py-2 rounded-lg transition-colors duration-200 border border-slate-700">
                Logout
            </a>
        </div>
    </nav>

    <!-- Main Content Container -->
    <div class="relative flex-1 w-full h-full">

        <!-- Live Navigation Floating Instructions Card -->
        <div id="instructions"
            class="absolute top-3 left-12 right-4 sm:right-auto sm:w-80 z-[1000] bg-slate-900/95 backdrop-blur-md border border-slate-800 rounded-xl p-4 shadow-2xl transition-all duration-300">
            <div class="flex items-center space-x-3 mb-2">
                <!-- Pulsing Ping Animation to show live status -->
                <span class="relative flex h-3 w-3">
                    <span
                        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-3 w-3 bg-sky-500"></span>
                </span>
                <h4 class="font-semibold text-white tracking-wide">Live Navigation</h4>
            </div>
            <p id="panel-desc"
                class="text-xs text-slate-400 leading-relaxed bg-slate-950/50 p-2.5 rounded-lg border border-slate-850">
                Detecting your live location...
            </p>
        </div>
        <!-- The Leaflet Map Instance Container -->
        <div id="map" class="w-full h-full bg-slate-950"></div>

        <!-- Leaflet JS -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"
            integrity="sha512-puJW3E/qXDqYp9IfhAI54BJEaWIfloJ7JWs7OeD5i6ruC9JZL1gERT1wjtwXFlh7CjE7ZJ+/vcRZRkIYIb6p4g=="
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>

        <!-- Leaflet Routing Machine JS -->
        <script
            src="https://cdnjs.cloudflare.com/ajax/libs/leaflet-routing-machine/3.2.12/leaflet-routing-machine.min.js"></script>

        <!-- Socket.io -->
        <script src="/socket.io/socket.io.js"></script>

        <script>
            const socket = io();
            const currentUserName = "<%= user.name %>";

            // Join socket room
            socket.emit('join-family', currentUserName);

            // Initialize Map
            const map = L.map('map').setView([20, 78], 5);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: 'RakshaPath Map'
            }).addTo(map);

            let myMarker = null;
            let destinationMarker = null;
            let myCurrentLatLng = null;
            let routingControl = null;

            const panelDesc = document.getElementById('panel-desc');

            // --- GPS LIVE LOCATION TRACKING ---
            if (navigator.geolocation) {
                navigator.geolocation.watchPosition((position) => {
                    const { latitude, longitude } = position.coords;
                    const newLatLng = L.latLng(latitude, longitude);
                    const isFirstLoad = !myCurrentLatLng;

                    myCurrentLatLng = newLatLng;

                    // Send live GPS update to server
                    socket.emit('send-Location', { latitude, longitude, username: currentUserName });

                    // Update or Draw standard blue marker for Current Location
                    if (myMarker) {
                        myMarker.setLatLng(myCurrentLatLng);
                    } else {
                        myMarker = L.marker(myCurrentLatLng).addTo(map).bindPopup("<b>You are here</b>").openPopup();
                    }

                    // Focus camera on first load
                    if (isFirstLoad) {
                        map.setView(myCurrentLatLng, 15);
                        panelDesc.innerText = "Click anywhere on the map to set your destination.";
                    }

                    // Auto-recalculate route if you move while a destination is active
                    if (routingControl && destinationMarker) {
                        drawRoute(myCurrentLatLng, destinationMarker.getLatLng());
                    }

                }, (error) => {
                    console.error(error);
                    panelDesc.innerText = "GPS Error. Check your location permissions.";
                }, {
                    enableHighAccuracy: true,
                    timeout: 5000,
                    maximumAge: 0
                });
            } else {
                panelDesc.innerText = "Geolocation is not supported by your browser.";
            }

            // --- MAP CLICK HANDLER ---
            map.on('click', (e) => {
                if (!myCurrentLatLng) {
                    alert("Waiting for your live location...");
                    return;
                }

                const destinationLatLng = e.latlng;

                // Set or update standard blue marker for Destination
                if (destinationMarker) {
                    destinationMarker.setLatLng(destinationLatLng);
                } else {
                    destinationMarker = L.marker(destinationLatLng).addTo(map).bindPopup("<b>Destination</b>").openPopup();
                }

                panelDesc.innerText = "Finding shortest path...";
                drawRoute(myCurrentLatLng, destinationLatLng);
            });

            // --- ROUTE MAKER ENGINE ---
            function drawRoute(start, end) {
                if (routingControl) {
                    map.removeControl(routingControl);
                }

                routingControl = L.Routing.control({
                    waypoints: [start, end],
                    router: L.Routing.osrmv1({
                        serviceUrl: 'https://router.project-osrm.org/route/v1',
                        profile: 'car'
                    }),
                    createMarker: function () { return null; }, // Prevents duplicate/routing-machine default markers
                    lineOptions: {
                        styles: [{ color: '#0078ff', opacity: 0.8, weight: 6 }] // Standard blue routing line
                    },
                    addWaypoints: false,
                    show: false
                }).addTo(map);

                routingControl.on('routesfound', function (e) {
                    const distance = (e.routes[0].summary.totalDistance / 1000).toFixed(2);
                    const time = Math.round(e.routes[0].summary.totalTime / 60);
                    panelDesc.innerText = `Route Set! Distance: ${distance} km | Time: ${time} mins`;
                });

                routingControl.on('routingerror', function () {
                    panelDesc.innerText = "Unable to compute route to this location.";
                });
            }
        </script>
    </div>
</body>

</html>